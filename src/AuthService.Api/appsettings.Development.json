{
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5061",
      "http://localhost:3000",
      "http://localhost:5173"
    ]
  },
  "ConnectionStrings": {
    "AuthDb": "Host=localhost;Port=5434;Database=auth_service;Username=auth_service_user;Password=auth_service_password;Pooling=true;Minimum Pool Size=2;Maximum Pool Size=50"
  },
  "Database": {
    "DbContextPoolSize": 64,
    "CommandTimeoutSeconds": 30,
    "MaxRetryCount": 3,
    "MaxRetryDelaySeconds": 5
  },
  "OpenIddict": {
    "SeedOnStartup": true
  },
  "Maintenance": {
    "Retention": {
      "Enabled": true,
      "CleanupBatchSize": 100,
      "CleanupIntervalMinutes": 5
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
