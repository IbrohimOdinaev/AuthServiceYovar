{
  "Cors": {
    "AllowedOrigins": []
  },
  "Database": {
    "DbContextPoolSize": 128,
    "CommandTimeoutSeconds": 30,
    "MaxRetryCount": 3,
    "MaxRetryDelaySeconds": 5
  },
  "Maintenance": {
    "Retention": {
      "Enabled": false,
      "AuditEventsRetentionDays": 180,
      "LoginAttemptsRetentionDays": 90,
      "RevokedSessionsRetentionDays": 90,
      "CleanupBatchSize": 500,
      "CleanupIntervalMinutes": 60
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "OpenIddict": {
    "SeedOnStartup": false,
    "Certificates": {
      "SigningCertificatePath": "",
      "SigningCertificatePassword": "",
      "EncryptionCertificatePath": "",
      "EncryptionCertificatePassword": ""
    }
  }
}
