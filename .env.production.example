ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://0.0.0.0:8080

POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

ConnectionStrings__AuthDb=Host=postgres;Port=5432;Database=auth_service;Username=auth_service_user;Password=CHANGE_ME_STRONG_PASSWORD;Pooling=true;Minimum Pool Size=10;Maximum Pool Size=100

Cors__AllowedOrigins__0=https://app.example.com
Cors__AllowedOrigins__1=https://admin.example.com

OpenIddict__SeedOnStartup=false
OpenIddict__Certificates__SigningCertificatePath=/run/secrets/authservice-signing.pfx
OpenIddict__Certificates__SigningCertificatePassword=CHANGE_ME_CERT_PASSWORD
OpenIddict__Certificates__EncryptionCertificatePath=/run/secrets/authservice-encryption.pfx
OpenIddict__Certificates__EncryptionCertificatePassword=CHANGE_ME_CERT_PASSWORD

Database__DbContextPoolSize=256
Database__CommandTimeoutSeconds=30
Database__MaxRetryCount=3
Database__MaxRetryDelaySeconds=5

Maintenance__Retention__Enabled=true
Maintenance__Retention__AuditEventsRetentionDays=180
Maintenance__Retention__LoginAttemptsRetentionDays=90
Maintenance__Retention__RevokedSessionsRetentionDays=90
Maintenance__Retention__CleanupBatchSize=500
Maintenance__Retention__CleanupIntervalMinutes=60
